type FeatureItem = {
  title: string;
  text: string;
};

export function FeatureGrid({ items }: Readonly<{ items: FeatureItem[] }>) {
  return (
    <div className="feature-grid">
      {items.map((item, index) => (
        <div className="feature-card" key={item.title}>
          <div className="feature-icon">{index + 1}</div>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </div>
      ))}
    </div>
  );
}
